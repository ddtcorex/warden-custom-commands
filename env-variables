#!/usr/bin/env bash
# Source Warden utilities
[[ -f "${WARDEN_DIR}/utils/env.sh" ]] && source "${WARDEN_DIR}/utils/env.sh"
[[ ! "${WARDEN_DIR:-}" ]] && >&2 printf "\033[31mThis script is not intended to be run directly!\033[0m\n" && exit 1

# Enable strict mode for all commands
set -euo pipefail

# Use SUBCOMMAND_DIR if already set by calling script, otherwise determine it
SUBCOMMAND_DIR="${SUBCOMMAND_DIR:-${WARDEN_HOME_DIR}/commands}"

# Source error handling utilities
source "${SUBCOMMAND_DIR}/lib/error-handling.sh"

function :: {
    printf "\n"
    printf "\033[33m%s\033[0m\n" "$*"
}

function array_contains() {
    local array="$1[@]"
    local seeking="${2}"
    local in_array=1
    for element in "${!array}"; do
        if [[ "${element}" == "${seeking}" ]]; then
            in_array=0
            break
        fi
    done
    printf "%s" "${in_array}"
}

function get_remote_details() {
    local env_name="${1}"
    local prefix="REMOTE_$(printf "%s" "${env_name}" | tr '[:lower:]' '[:upper:]')"
    
    # Handle aliases
    if [[ "${prefix}" == "REMOTE_PRODUCTION" ]]; then
        prefix="REMOTE_PROD"
    elif [[ "${prefix}" == "REMOTE_STAG" || "${prefix}" == "REMOTE_STG" || "${prefix}" == "REMOTE_PREPROD" ]]; then
        prefix="REMOTE_STAGING"
    elif [[ "${prefix}" == "REMOTE_DEVELOP" || "${prefix}" == "REMOTE_DEVELOPER" || "${prefix}" == "REMOTE_DEVELOPMENT" ]]; then
        prefix="REMOTE_DEV"
    fi

    local host_var="${prefix}_HOST"
    local user_var="${prefix}_USER"
    local port_var="${prefix}_PORT"
    local path_var="${prefix}_PATH"

    if [[ -n "${!host_var:-}" ]]; then
        printf "%s|%s|%s|%s" "${!host_var}" "${!user_var:-}" "${!port_var:-22}" "${!path_var:-}"
    fi
}

WARDEN_ENV_PATH="$(locateEnvPath)" || exit $?

loadEnvConfig "${WARDEN_ENV_PATH}" || exit $?

# Explicitly map and initialize common Warden variables to avoid "unbound variable" errors with set -u
DB_PREFIX="${WARDEN_DB_PREFIX:-}"
export DB_PREFIX

if [[ -f "${WARDEN_ENV_PATH}/.env" ]]; then
    eval "$(grep -E '^(CLOUD_|REMOTE_)' "${WARDEN_ENV_PATH}/.env" | sed 's/\r$//g')"
fi

assertDockerRunning

cd "${WARDEN_ENV_PATH}"

ENV_SOURCE_DEFAULT=0
ENV_SOURCE="${ENV_SOURCE:-}"
ENV_DESTINATION="${ENV_DESTINATION:-}"

export VERBOSE="${VERBOSE:-0}"
export VERBOSE_FLAG="${VERBOSE_FLAG:-}"

# Parse source/destination arguments and build filtered args list
declare -a SKIP_INDICES=()
declare -a FILTERED_ARGS=()

for (( i=1; i <= "$#"; i++ )); do
    case "${!i}" in
        --environment=*|-e=*|--e=*|--source=*|-s=*)
            ENV_SOURCE="${!i#*=}"
            SKIP_INDICES+=($i)
            ;;
        -e|-s|--source|--environment)
            j=$(($i+1))
            ENV_SOURCE="${!j}"
            SKIP_INDICES+=($i $j)
            ;;
        -d=*|--destination=*)
            ENV_DESTINATION="${!i#*=}"
            SKIP_INDICES+=($i)
            ;;
        -d|--destination)
            j=$(($i+1))
            ENV_DESTINATION="${!j}"
            SKIP_INDICES+=($i $j)
            ;;
        -v|--verbose)
            export VERBOSE=1
            export VERBOSE_FLAG="-v"
            SKIP_INDICES+=($i)
            ;;
    esac
done

# Build filtered args (excluding source/destination flags)
for (( i=1; i <= "$#"; i++ )); do
    skip=0
    if [[ ${#SKIP_INDICES[@]} -gt 0 ]]; then
        for idx in "${SKIP_INDICES[@]}"; do
            if [[ "$i" -eq "$idx" ]]; then
                skip=1
                break
            fi
        done
    fi
    if [[ "$skip" -eq 0 ]]; then
        FILTERED_ARGS+=("${!i}")
    fi
done

# Update positional parameters with filtered args
set -- "${FILTERED_ARGS[@]}"

if [[ -z "${ENV_SOURCE:-}" ]]; then
    ENV_SOURCE=staging
    ENV_SOURCE_DEFAULT=1
fi

ENV_SOURCE_ORIG="${ENV_SOURCE}"
ENV_SOURCE_VAR=$(printf "%s" "${ENV_SOURCE}" | tr '[:lower:]' '[:upper:]')

if [[ "${ENV_SOURCE_VAR}" == "PRODUCTION" ]]; then
    ENV_SOURCE_VAR="PROD"
elif [[ "${ENV_SOURCE_VAR}" == "STAG" || "${ENV_SOURCE_VAR}" == "STG" || "${ENV_SOURCE_VAR}" == "PREPROD" ]]; then
    ENV_SOURCE_VAR="STAGING"
elif [[ "${ENV_SOURCE_VAR}" == "DEVELOP" || "${ENV_SOURCE_VAR}" == "DEVELOPER" || "${ENV_SOURCE_VAR}" == "DEVELOPMENT" ]]; then
    ENV_SOURCE_VAR="DEV"
fi

ENV_SOURCE=$(printf "%s" "${ENV_SOURCE_VAR}" | tr '[:upper:]' '[:lower:]')
ENV_SOURCE_HOST_VAR="REMOTE_${ENV_SOURCE_VAR}_HOST"

if [[ -n "${!ENV_SOURCE_HOST_VAR+x}" ]]; then
    VAR_USER="REMOTE_${ENV_SOURCE_VAR}_USER"
    VAR_PORT="REMOTE_${ENV_SOURCE_VAR}_PORT"
    VAR_PATH="REMOTE_${ENV_SOURCE_VAR}_PATH"
    VAR_URL="REMOTE_${ENV_SOURCE_VAR}_URL"

    ENV_SOURCE_HOST="${!ENV_SOURCE_HOST_VAR}"
    ENV_SOURCE_USER="${!VAR_USER:-}"
    ENV_SOURCE_PORT="${!VAR_PORT:-22}"
    ENV_SOURCE_DIR="${!VAR_PATH:-}"
    ENV_SOURCE_URL="${!VAR_URL:-}"

    SSH_OPTS="-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null -o LogLevel=ERROR -o BatchMode=yes"
    if [[ -n "${SSH_AUTH_SOCK:-}" ]]; then
        SSH_OPTS="${SSH_OPTS} -A"
    fi
    if [[ "${WARDEN_SSH_IDENTITIES_ONLY:-0}" -eq 1 ]]; then
        SSH_OPTS="${SSH_OPTS} -o IdentitiesOnly=yes"
    fi
    if [[ -n "${WARDEN_SSH_IDENTITY_FILE:-}" ]]; then
        SSH_OPTS="${SSH_OPTS} -i ${WARDEN_SSH_IDENTITY_FILE}"
    fi
elif [[ "${ENV_SOURCE_DEFAULT:-0}" -eq 0 ]] && [[ "${ENV_SOURCE_VAR}" != "LOCAL" ]]; then
    printf "\033[31mError: Environment details not found for '%s'. Check your .env file.\033[0m\n" "${ENV_SOURCE}" >&2
    exit 1
fi
