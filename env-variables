#!/usr/bin/env bash
# Source Warden utilities
[[ -f "${WARDEN_DIR}/utils/env.sh" ]] && source "${WARDEN_DIR}/utils/env.sh"

[[ ! "${WARDEN_DIR:-}" ]] && >&2 printf "\033[31mThis script is not intended to be run directly!\033[0m\n" && exit 1

# Enable strict mode for all commands
set -euo pipefail

# Use SUBCOMMAND_DIR if already set by calling script, otherwise determine it
SUBCOMMAND_DIR="${SUBCOMMAND_DIR:-${WARDEN_HOME_DIR}/commands}"

# Source error handling utilities
source "${SUBCOMMAND_DIR}/lib/error-handling.sh"

# Source shared SSH utilities
source "${SUBCOMMAND_DIR}/lib/ssh-utils.sh"

function :: {
    printf "\n"
    printf "\033[33m%s\033[0m\n" "$*"
}

function array_contains() {
    local array="$1[@]"
    local seeking="${2}"
    local in_array=1
    for element in "${!array}"; do
        if [[ "${element}" == "${seeking}" ]]; then
            in_array=0
            break
        fi
    done
    printf "%s" "${in_array}"
}

function get_remote_details() {
    local env_name="${1}"
    local prefix="REMOTE_$(printf "%s" "${env_name}" | tr '[:lower:]' '[:upper:]')"
    
    # Handle aliases
    if [[ "${prefix}" == "REMOTE_PRODUCTION" ]]; then
        prefix="REMOTE_PROD"
    elif [[ "${prefix}" == "REMOTE_STAG" || "${prefix}" == "REMOTE_STG" || "${prefix}" == "REMOTE_PREPROD" ]]; then
        prefix="REMOTE_STAGING"
    elif [[ "${prefix}" == "REMOTE_DEVELOP" || "${prefix}" == "REMOTE_DEVELOPER" || "${prefix}" == "REMOTE_DEVELOPMENT" ]]; then
        prefix="REMOTE_DEV"
    fi

    local host_var="${prefix}_HOST"
    local user_var="${prefix}_USER"
    local port_var="${prefix}_PORT"
    local path_var="${prefix}_PATH"

    if [[ -n "${!host_var:-}" ]]; then
        printf "%s|%s|%s|%s" "${!host_var}" "${!user_var:-}" "${!port_var:-22}" "${!path_var:-}"
    fi
}

function detect_magento_version() {
    local detected_version=""
    
    # 1. Try to get version from composer.json reliably
    if [[ -f "composer.json" ]]; then
        local composer_ver=$(grep -oE '"magento/product-(community|enterprise)-edition":\s*"[^"]+"' composer.json 2>/dev/null | awk 'NR==1' | grep -oE '[0-9]+\.[0-9]+\.[0-9]+(-p[0-9]+)?' | awk 'NR==1')
        if [[ -n "${composer_ver}" ]]; then
            detected_version="${composer_ver}"
        elif command -v jq &> /dev/null; then
            # Fallback to jq if grep logic doesn't match for some reason
            composer_ver=$(jq -r '.require["magento/product-community-edition"] // .require["magento/product-enterprise-edition"] // "unknown"' composer.json | sed 's/[\^~]//g')
            if [[ "${composer_ver}" != "unknown" ]]; then
                detected_version="${composer_ver}"
            fi
        fi
    fi
    
    # 2. Fall back to installed version if available and php-fpm is running
    if [[ -z "${detected_version}" ]]; then
        # Check if php-fpm container is running before attempting to execute
        if warden env exec -T php-fpm true &> /dev/null; then
            local cli_ver=$(warden env exec -T php-fpm bin/magento --version 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+(-p[0-9]+)?' | awk 'NR==1')
            if [[ -n "${cli_ver}" ]]; then
                detected_version="${cli_ver}"
            fi
        fi
    fi

    # Output the result
    printf "%s" "${detected_version}"
}

WARDEN_ENV_PATH="$(locateEnvPath)" || exit $?

loadEnvConfig "${WARDEN_ENV_PATH}" || exit $?

# Explicitly map and initialize common Warden variables to avoid "unbound variable" errors with set -u
DB_PREFIX="${WARDEN_DB_PREFIX:-}"
export DB_PREFIX

if [[ -f "${WARDEN_ENV_PATH}/.env" ]]; then
    eval "$(grep -E '^(CLOUD_|REMOTE_)' "${WARDEN_ENV_PATH}/.env" | sed 's/\r$//g')"
fi

assertDockerRunning

cd "${WARDEN_ENV_PATH}"

ENV_SOURCE_DEFAULT=${ENV_SOURCE_DEFAULT:-0}
ENV_SOURCE="${ENV_SOURCE:-}"
ENV_DESTINATION="${ENV_DESTINATION:-}"

export YES_TO_ALL="${YES_TO_ALL:-0}"

export VERBOSE="${VERBOSE:-0}"
export VERBOSE_FLAG="${VERBOSE_FLAG:-}"

# Parse source/destination arguments and build filtered args list
declare -a SKIP_INDICES=()
declare -a FILTERED_ARGS=()

for (( i=1; i <= "$#"; i++ )); do
    case "${!i}" in
        --environment=*|-e=*|--e=*|--source=*|-s=*)
            ENV_SOURCE="${!i#*=}"
            SKIP_INDICES+=($i)
            ;;
        -e|-s|--source|--environment)
            j=$(($i+1))
            if [[ -z "${!j:-}" ]] || [[ "${!j}" =~ ^- ]]; then
                printf "\033[31mError: Option %s requires an argument.\033[0m\n" "${!i}" >&2
                exit 1
            fi
            ENV_SOURCE="${!j}"
            SKIP_INDICES+=($i $j)
            ;;
        -d=*|--destination=*)
            ENV_DESTINATION="${!i#*=}"
            SKIP_INDICES+=($i)
            ;;
        -d|--destination)
            j=$(($i+1))
            if [[ -z "${!j:-}" ]] || [[ "${!j}" =~ ^- ]]; then
                printf "\033[31mError: Option %s requires an argument.\033[0m\n" "${!i}" >&2
                exit 1
            fi
            ENV_DESTINATION="${!j}"
            SKIP_INDICES+=($i $j)
            ;;
        -y|--yes)
            export YES_TO_ALL=1
            SKIP_INDICES+=($i)
            ;;
        -v|--verbose)
            export VERBOSE=$((VERBOSE + 1))
            SKIP_INDICES+=($i)
            ;;
        -vv)
            export VERBOSE=$((VERBOSE + 2))
            SKIP_INDICES+=($i)
            ;;
    esac
done

# Set VERBOSE_FLAG and debug mode based on cumulative verbosity
if [[ "${VERBOSE}" -ge 2 ]]; then
    export VERBOSE_FLAG="-vv"
    set -x
elif [[ "${VERBOSE}" -eq 1 ]]; then
    export VERBOSE_FLAG="-v"
else
    export VERBOSE_FLAG=""
fi

# Build filtered args (excluding source/destination flags)
for (( i=1; i <= "$#"; i++ )); do
    skip=0
    if [[ ${#SKIP_INDICES[@]} -gt 0 ]]; then
        for idx in "${SKIP_INDICES[@]}"; do
            if [[ "$i" -eq "$idx" ]]; then
                skip=1
                break
            fi
        done
    fi
    if [[ "$skip" -eq 0 ]]; then
        FILTERED_ARGS+=("${!i}")
    fi
done

# Update positional parameters with filtered args
set -- "${FILTERED_ARGS[@]}"

if [[ -z "${ENV_SOURCE:-}" ]]; then
    ENV_SOURCE=staging
    ENV_SOURCE_DEFAULT=1
fi

# Normalize ENVIRONMENT name (e.g. STAG -> STAGING)
ENV_SOURCE_VAR=$(normalize_env_name "${ENV_SOURCE}")
ENV_SOURCE=$(printf "%s" "${ENV_SOURCE_VAR}" | tr '[:upper:]' '[:lower:]')
# Legacy: Define variable name for adapters that check it directly (e.g. sync.cmd)
export ENV_SOURCE_HOST_VAR="REMOTE_${ENV_SOURCE_VAR}_HOST"

# Helper: Export remote variables (HOST, USER, PORT, etc.)
eval "$(get_remote_env "${ENV_SOURCE_VAR}")" || true

if [[ -n "${ENV_SOURCE_HOST:-}" ]]; then
    # Use shared builder for SSH options
    SSH_OPTS=$(build_ssh_opts)
elif [[ "${ENV_SOURCE_DEFAULT:-0}" -eq 0 ]] && [[ "${ENV_SOURCE_VAR}" != "LOCAL" ]]; then
    printf "\033[31mError: Environment details not found for '%s'. Check your .env file.\033[0m\n" "${ENV_SOURCE}" >&2
    exit 1
fi
