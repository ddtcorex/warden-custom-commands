# IDE
.idea
.vscode
*.swp
*.swo

# Test Environments (generated by warden env-init)
tests/project-local/
tests/project-dev/
tests/project-staging/

# Test Fixtures (can be regenerated)
tests/fixtures/

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
tests/integration/test_id_rsa
tests/integration/test_id_rsa.pub

# BATS test artifacts (generated during test runs)
tests/.env
tests/*.sql.gz
tests/dump.sql.gz
tests/composer.json
tests/**/dump.sql.gz
tests/**/.env

# Root-level test artifacts (should not be created, but just in case)
/composer.json
/.env
/dump.sql.gz
