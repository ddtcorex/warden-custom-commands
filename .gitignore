# IDE
.idea
.vscode
*.swp
*.swo

# Test Environments (generated by setup-test-envs.sh)
# Pattern: tests/{env-type}-{local|dev|staging}/
tests/*-local/
tests/*-dev/
tests/*-staging/

# Test Fixtures (can be regenerated)
tests/fixtures/

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
tests/integration/test_id_rsa
tests/integration/test_id_rsa.pub

# BATS test artifacts (generated during test runs)
tests/.tmp/
tests/unit/.tmp/

# NPX generated files
/.env
/composer.json
/wp-config.php
tests/.env
tests/composer.json
tests/wp-config.php
