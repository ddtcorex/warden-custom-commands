#!/usr/bin/env bash
[[ ! ${WARDEN_DIR} ]] && >&2 echo -e "\033[31mThis script is not intended to be run directly!\033[0m" && exit 1

WARDEN_USAGE=$(cat <<EOF
Pull the latest update and apply fixes/improvements

Usage:
  warden self-update [options]

Options:
  -f, --force      Force update, overwriting any local changes (uncommitted files)
  --dry-run        Simulate the update process without making changes
EOF
)
