#!/usr/bin/env bash
[[ ! "${WARDEN_DIR:-}" ]] && >&2 printf "\033[31mThis script is not intended to be run directly!\033[0m\n" && exit 1

read -r -d '' WARDEN_USAGE <<EOF
\033[33mUsage:\033[0m warden setup-remotes

Interactively configure remote environment details (Production, Staging, Development) in .env file.
EOF

echo -e "${WARDEN_USAGE}"
