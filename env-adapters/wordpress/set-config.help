#!/usr/bin/env bash
[[ ! ${WARDEN_DIR} ]] && >&2 echo -e "\033[31mThis script is not intended to be run directly!\033[0m" && exit 1

WARDEN_USAGE=$(cat <<HELP
## set-config

Update WordPress configuration for Warden environment.

### Synopsis

    warden set-config

### Description

Updates WordPress configuration including:
- Database connection settings in wp-config.php
- Redis configuration (if enabled)
- Flushes WordPress and Redis cache

### Examples

    warden set-config
HELP
)
