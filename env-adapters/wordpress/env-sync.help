#!/usr/bin/env bash
# Framework-specific sync reference (unused by Warden help system)
# This file documents WordPress-specific sync behavior

# WordPress Sync Paths and Exclusions:
#   --file    Sync code (excludes: wp-config.php, wp-content/uploads/*, wp-content/cache/*, .git, .env)
#   --media   Sync wp-content/uploads/ directory
#   --db      Stream database via mysqldump/mariadb-dump
#
# Special Behavior:
#   - Excludes wp-config.php when syncing to protect local config
#   - Flushes WordPress cache via WP-CLI after sync
