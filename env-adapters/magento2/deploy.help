#!/usr/bin/env bash
[[ ! ${WARDEN_DIR} ]] && >&2 echo -e "\033[31mThis script is not intended to be run directly!\033[0m" && exit 1

WARDEN_USAGE=$(cat <<EOF
Deploy Magento locally. By default, runs a full deployment.

\033[33mUsage:\033[0m
  deploy [-h|--help] [-e|--environment=<env>] [-o|--only-static] [-j|--jobs=<n>]
         [--deployer] [--strategy=<type>] [--deployer-config=<path>]

\033[33mOptions:\033[0m
  -h, --help                Display this help menu
  -v, --verbose             Print the command being executed

\033[33mArguments:\033[0m
  -e, --environment=<env>   Remote environment to deploy to (e.g. staging, prod). Default: local

  -o, --only-static         Deploy static files only (skip composer, upgrade, compile)

  -j, --jobs=<n>            Number of parallel jobs for static content deploy. Default: 4

\033[33mDeployer Strategy:\033[0m
  --deployer                Use Deployer instead of native deployment (equivalent to --strategy=deployer)

  --strategy=<type>         Deployment strategy: 'native' (default) or 'deployer'

  --deployer-config=<path>  Path to deployer config file. Auto-detects from:
                            .deployer/deploy.php, .deployer/deploy.yaml, deploy.php, deploy.yaml

EOF
)
