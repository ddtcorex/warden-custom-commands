#!/usr/bin/env bash
# Framework-specific sync reference (unused by Warden help system)
# This file documents Magento 2-specific sync behavior

# Magento 2 Sync Paths and Exclusions:
#   --file    Sync code (excludes: generated/, var/, pub/media/, pub/static/, .git, node_modules)
#   --media   Sync pub/media/ (excludes: cache, tmp, import/export, catalog/product by default)
#   --db      Stream database via mysqldump/mariadb-dump with n98-magerun2 support
#
# Special Behavior:
#   - Excludes app/etc/env.php when syncing to protect local config
#   - Use --include-product to sync catalog/product images (excluded by default)
