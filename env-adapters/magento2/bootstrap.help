#!/usr/bin/env bash
[[ ! ${WARDEN_DIR} ]] && >&2 echo -e "\033[31mThis script is not intended to be run directly!\033[0m" && exit 1

WARDEN_USAGE=$(cat <<EOF
\033[33mUsage:\033[0m
  bootstrap [-e|--environment=<env>] [options]

\033[33mClone Options:\033[0m
  -c, --clone             Clone project from remote (source + DB + media)
  --code-only             With --clone: skip DB and media sync

\033[33mInstall Options:\033[0m
  --fresh                 Fresh Magento installation (create new project)
  --hyva-install          Install Hyvä theme (with --fresh only)
  --include-sample        Include sample data (with --fresh only)

  --meta-package=PKG      Magento package (magento/project-community-edition)
  --meta-version=VER      Magento version (e.g., 2.4.7)

  --mage-username=KEY     Magento Marketplace Public Key
  --mage-password=KEY     Magento Marketplace Private Key

\033[33mSkip Options:\033[0m
  --no-db                 Skip database import
  --no-media              Skip media sync
  --no-composer           Skip composer install
  --no-admin              Skip admin user creation
  --no-stream-db          Download dump file instead of streaming

\033[33mDatabase Options:\033[0m
  --db-dump=FILE          Use local SQL dump file for import
  --no-noise            Exclude noise tables (logs/cache/indexes) in DB sync
  --no-pii Exclude PII/sensitive data from DB sync

\033[33mCommon Options:\033[0m
  -e, --environment=NAME  Source environment (staging, prod, dev). Default: staging
  -y, --yes               Non-interactive mode
  -h, --help              Display this help

\033[33mExamples:\033[0m
  warden bootstrap                           # Standard bootstrap from staging
  warden bootstrap -c -e prod                # Clone from prod
  warden bootstrap -c --code-only -e staging # Clone code only, skip DB/media
  warden bootstrap --fresh --meta-version=2.4.7  # Fresh Magento 2.4.7 install

EOF
)

