#!/usr/bin/env bash
[[ ! ${WARDEN_DIR} ]] && >&2 echo -e "\033[31mThis script is not intended to be run directly!\033[0m" && exit 1

WARDEN_USAGE=$(cat <<EOF
Configure Magento for local development environment. This command sets up
the application with appropriate settings for Varnish, Elasticsearch/OpenSearch,
Redis, URLs, admin security, and other development-friendly configurations.

\033[33mUsage:\033[0m
  set-config [-h|--help]

\033[33mOptions:\033[0m
  -h, --help                   Display this help menu

\033[33mFeatures:\033[0m
  - Runs setup:upgrade and app:config:import
  - Configures Varnish (if WARDEN_VARNISH=1)
  - Configures Elasticsearch/OpenSearch based on Magento version
  - Configures Redis for cache, page cache, and sessions (if WARDEN_REDIS=1)
  - Sets base URLs to match Traefik configuration
  - Disables security features for development (2FA, reCAPTCHA, CAPTCHA)
  - Enables developer mode
  - Configures PWA theme (if WARDEN_PWA=1)
  - Flushes cache and reindexes data

\033[33mEnvironment Variables:\033[0m
  WARDEN_VARNISH               Enable Varnish configuration (0 or 1)
  WARDEN_ELASTICSEARCH         Enable Elasticsearch configuration (0 or 1)
  WARDEN_OPENSEARCH            Enable OpenSearch configuration (0 or 1)
  WARDEN_REDIS                 Enable Redis configuration (0 or 1)
  WARDEN_PWA                   Enable PWA theme configuration (0 or 1)

\033[33mExamples:\033[0m
  warden set-config                       # Apply all configurations

\033[33mHooks:\033[0m
  before_set_config()          Called before URL and config updates
  after_set_config()           Called after URL and config updates

  Define these functions in .warden/hooks to customize behavior.

EOF
)
